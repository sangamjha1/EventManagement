<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <style>
      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: #f7f7fb;
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        color: #111827;
      }
      .card {
        background: #ffffff;
        padding: 28px;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.1);
        width: min(420px, 92vw);
      }
      h1 {
        margin: 0 0 8px;
        font-size: 1.5rem;
      }
      p {
        margin: 0 0 18px;
        color: #6b7280;
      }
      label {
        display: grid;
        gap: 6px;
        font-size: 0.9rem;
        color: #6b7280;
        margin-bottom: 12px;
      }
      input {
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        font-size: 1rem;
      }
      button {
        width: 100%;
        padding: 12px 16px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(120deg, #ff8a65, #ff6b6b);
        color: #ffffff;
        font-weight: 600;
        cursor: pointer;
      }
      .hint {
        margin-top: 12px;
        font-size: 0.85rem;
        color: #9ca3af;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Reset your password</h1>
      <p>Enter a new password to regain access.</p>
      <form method="POST" action="/reset-password">
        <label>
          New password
          <input type="password" name="password" minlength="8" required />
        </label>
        <label>
          Confirm new password
          <input type="password" name="confirmPassword" minlength="8" required />
        </label>
        <button type="submit">Update password</button>
      </form>
      <div class="hint">You will be redirected to login after a successful reset.</div>
    </div>
  </body>
</html>
