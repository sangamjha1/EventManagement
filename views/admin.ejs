<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EventFlow Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="admin-body">
    <main class="container admin-wrap">
      <section id="adminLogin" class="card" style="padding:1rem;max-width:460px;">
        <h1>Admin Access</h1>
        <p>Restricted monitoring console for platform data and quality control.</p>
        <form id="adminLoginForm" class="auth-form">
          <input type="email" name="email" placeholder="Admin email" required />
          <input type="password" name="password" placeholder="Password" required />
          <button class="btn primary" type="submit">Login</button>
        </form>
      </section>

      <section id="adminDashboard" class="hidden">
        <div class="section-head">
          <h1>Platform Dashboard</h1>
          <button id="adminLogout" class="btn ghost">Logout</button>
        </div>

        <div id="adminTotals" class="admin-totals"></div>

        <div class="admin-grid">
          <article class="card" style="padding:0.9rem;">
            <h3>Recent Opportunities</h3>
            <div id="adminEvents"></div>
          </article>
          <article class="card" style="padding:0.9rem;">
            <h3>Recent Applications</h3>
            <div id="adminRegistrations"></div>
          </article>
        </div>

        <div class="admin-grid" style="margin-top:0.8rem;">
          <article class="card" style="padding:0.9rem;">
            <h3>Category Distribution</h3>
            <div id="adminCategory"></div>
          </article>
          <article class="card" style="padding:0.9rem;">
            <h3>Status Distribution</h3>
            <div id="adminStatus"></div>
          </article>
        </div>

        <article class="card" style="padding:0.9rem;margin-top:0.8rem;">
          <h3>Top Organizers</h3>
          <div id="adminOrganizers"></div>
        </article>
      </section>
    </main>

    <div id="toast" class="toast hidden"></div>

    <script src="/js/admin.js"></script>
  </body>
</html>